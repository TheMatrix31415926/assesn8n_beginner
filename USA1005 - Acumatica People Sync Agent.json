    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst memory = $getWorkflowStaticData('global');\n\n// Update memory to mark as success\nmemory[item.record_key] = {\n  run_id: item.run_id,\n  processed_at: item.processed_at,\n  status: 'success'\n};\n\nreturn {\n  json: {\n    ...item,\n    status: 'success',\n    log_message: `✅ SUCCESS: ${item.full_name} saved to sheet`\n  }\n};"
      },
