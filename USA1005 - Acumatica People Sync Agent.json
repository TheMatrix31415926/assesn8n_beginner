    {
      "parameters": {
        "jsCode": "const memory = $getWorkflowStaticData('global');\n\n// Count all statuses\nconst allRecords = Object.values(memory);\nconst success = allRecords.filter(r => r.status === 'success').length;\nconst duplicates = allRecords.filter(r => r.status === 'duplicate').length;\nconst skipped = allRecords.filter(r => r.status === 'skipped').length;\n\nreturn {\n  json: {\n    log_message: ` WORKFLOW COMPLETE`,\n    total_processed: allRecords.length,\n    success_count: success,\n    duplicate_count: duplicates,\n    skipped_count: skipped,\n    completed_at: new Date().toISOString()\n  }\n};"
      },
