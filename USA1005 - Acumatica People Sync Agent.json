    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  \"id\",\n  COALESCE(\n    NULLIF(TRIM(\"fullName\"),''), \n    NULLIF(TRIM(\"originalFullName\"),'')\n  ) AS full_name,\n  TRIM(\"jobTitle\") AS job_title,\n  \"profileUrlPrimaryLinkUrl\" AS linkedin_profile,\n  \"status\"\nFROM \"_peopleraw\"\nWHERE\n  \"status\" IN (\n    '1 - ExtractedWithUniqueID',\n    '3 - UniqueIDIdentified',\n    '6 - UniqueFound-CRM Pending',\n    '7 - CRMCompleted'\n  )\n  AND \"jobTitle\" ILIKE '%acumatica%'\n  AND \"jobTitle\" NOT ILIKE '%ex%'\n  AND \"jobTitle\" NOT ILIKE '%former%'\n  AND \"jobTitle\" NOT ILIKE '%previous%'\n  AND (\n    \"profileUrlPrimaryLinkUrl\" = '{{ $json.linkedin_profile }}'\n    OR TRIM(\"fullName\") ILIKE '{{ $json.full_name }}'\n  )\nORDER BY full_name NULLS LAST\nLIMIT 1;",
        "options": {}
      },
