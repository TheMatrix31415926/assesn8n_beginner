    {
      "parameters": {
        "jsCode": "// Get this record's unique key (linkedin or name)\nconst item = $input.first().json;\nconst recordKey = (item.linkedin_profile || item.full_name || '')\n  .trim()\n  .replace(/[^a-zA-Z0-9]/g, '_')\n  .toLowerCase();\n\n// Get n8n's internal memory\nconst memory = $getWorkflowStaticData('global');\n\n// Check if we have seen this record before\nif (memory[recordKey]) {\n  // DUPLICATE FOUND\n  return {\n    json: {\n      ...item,\n      status: 'duplicate',\n      duplicate_detected: true,\n      record_key: recordKey,\n      error_message: 'Duplicate: record already processed in a previous run'\n    }\n  };\n} else {\n  // NEW RECORD - save to memory\n  memory[recordKey] = {\n    run_id: item.run_id,\n    processed_at: item.processed_at,\n    status: 'processing'\n  };\n\n  // NEW RECORD - pass forward\n  return {\n    json: {\n      ...item,\n      status: 'processing',\n      duplicate_detected: false,\n      record_key: recordKey\n    }\n  };\n}"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
