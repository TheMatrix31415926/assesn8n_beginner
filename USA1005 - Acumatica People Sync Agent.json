    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst memory = $getWorkflowStaticData('global');\n\n// Update memory to mark as skipped\nif (item.record_key) {\n  memory[item.record_key] = {\n    run_id: item.run_id,\n    processed_at: item.processed_at,\n    status: 'skipped'\n  };\n}\n\nreturn {\n  json: {\n    ...item,\n    status: 'skipped',\n    log_message: `⏭️ SKIPPED: ${item.full_name} failed quality check`\n  }\n};"
      },
